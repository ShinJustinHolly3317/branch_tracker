# Copy to `.env` locally; never commit real credentials (`.env` is gitignored).

# Postgres（API / ingester）— Dashboard → Database → Connection string（建議 sslmode=require）
DATABASE_URL=

# Supabase — Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable（原 anon）— 前端直連或需搭配 RLS；勿當 service_role 用
SUPABASE_ANON_KEY=

# Service role — 僅後端 server；絕不可進瀏覽器 bundle
SUPABASE_SERVICE_ROLE_KEY=
