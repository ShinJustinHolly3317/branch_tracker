# 本機 Postgres（docker-compose 預設；sync:supabase 的 source 預設也是這組）
# SOURCE_DB_URL=postgres://twbbd:twbbd@localhost:5432/twbbd

# Supabase（sync:supabase 會把 DATABASE_URL 當 target）
DATABASE_URL=postgres://twbbd:twbbd@localhost:5432/twbbd

# 前端打包時請指向正式 HTTPS API（不要有結尾 slash）
VITE_API_BASE=http://localhost:8787

# --- Supabase 範例（Transaction pool／6543 埠為常見組合）---
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres?sslmode=require

# （選）API｜進階：Serverless 上的 Pg Pool 連線數上限（整數）
# API_PG_POOL_MAX=2

# --- ingest（對照 README）---
# TWSE_STOCKS=all
# TW_STOCK_UNIVERSE=twse
# INGEST_MS_BETWEEN_STOCKS=350
# INGEST_CONCURRENCY=5
# DEBUG_INGEST=0
